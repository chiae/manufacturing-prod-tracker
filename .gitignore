## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
bin/
obj/
out/

# User-specific files
*.user
*.userosscache
*.suo
*.sln.docstates

# Visual Studio cache
.vs/

# NuGet
*.nupkg
*.snupkg
packages/
*.nuget.props
*.nuget.targets

# Logs
*.log

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Rider
.idea/

# DotCover
*.dotCover

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Publish output
wwwroot/

# Blazor WebAssembly
**/obj/
**/bin/
*.blat
*.dll.gz
*.wasm.gz
*.json.gz

# EF Core Migrations (generated files)
**/Migrations/*Designer.cs
**/Migrations/*Snapshot.cs

# SQLite / Local DB
*.db
*.db-shm
*.db-wal

# Temp files
*.tmp
*.temp

# OS-specific
.DS_Store
Thumbs.db
